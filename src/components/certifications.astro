---
import { Icon } from 'astro-icon/components';
import localCertData from '../data/certifications.json';

interface Certification {
  name: string;
  icon: string;
}

const certifications: Certification[] = localCertData;
---

<section id="certifications" class="section-container overflow-hidden">
  <div class="container mx-auto">
    <div class="cert-header flex flex-col gap-2 mb-16">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-white flex items-center gap-4">
        <span class="text-accent">/</span> Certifications
      </h2>
      <p class="text-gray font-body text-sm max-w-md">
        Salesforce professional certifications
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {certifications.map((cert) => (
        <div class="cert-card opacity-0 flex items-center gap-4 p-4 rounded-xl bg-white/5 border border-white/10 hover:border-accent/40 hover:bg-white/8 transition-all duration-300">
          <div class="shrink-0 w-12 h-12 flex items-center justify-center rounded-xl bg-white/5">
            <Icon name={cert.icon} class="w-7 h-7 text-accent" />
          </div>
          <span class="font-body text-white/90 text-sm font-medium leading-snug">{cert.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .cert-header {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cert-card {
    transform: translateY(20px) scale(0.95);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cert-header.reveal,
  .cert-card.reveal {
    opacity: 1 !important;
    transform: translateY(0) scale(1);
  }
</style>

<script>
  function revealCerts() {
    const header = document.querySelector('.cert-header');
    const cards = document.querySelectorAll('.cert-card');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const target = entry.target;
          if (target.classList.contains('cert-header')) {
            target.classList.add('reveal');
            observer.unobserve(target);
          } else if (target.classList.contains('cert-card')) {
            const index = Array.from(cards).indexOf(target);
            setTimeout(() => {
              target.classList.add('reveal');
            }, (index % 3) * 80);
            observer.unobserve(target);
          }
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    });

    if (header) observer.observe(header);
    cards.forEach(card => observer.observe(card));
  }

  revealCerts();
  document.addEventListener('astro:after-swap', revealCerts);
</script>
